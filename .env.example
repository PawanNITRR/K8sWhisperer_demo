# --- Local demo (recommended): mock cluster + no external LLM ---
MOCK_CLUSTER=1
LLM_PROVIDER=mock

# LLM (openai | anthropic | gemini | mock)
# LLM_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini / Google AI Studio API key (only if LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Optional: full path to kubectl.exe if `kubectl` is not on PATH (project also checks tools/kubectl.exe)
# KUBECTL_PATH=C:\path\to\kubectl.exe

# Optional: kubectl context name (leave empty for current kubeconfig default)
KUBECTL_CONTEXT=

# No real Kubernetes API: use built-in mock CrashLoop scenario (good for Windows without kubectl/cluster)
# MOCK_CLUSTER=1

# Optional Prometheus (CPU throttling / metrics in Observe)
PROMETHEUS_BASE_URL=http://localhost:9090

# Slack HITL (optional)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=

# API (FastAPI webhook for Slack interactions)
API_HOST=0.0.0.0
API_PORT=8080

# Persistence
AUDIT_LOG_PATH=audit_log.json
STATE_STORE_PATH=data/state_store.json

# Dashboard: allow JSON POST /slack/interactive from the UI (always allowed when MOCK_CLUSTER=1)
# DASHBOARD_HITL=1

# Comma-separated browser origins for CORS (Vite default ports included in config defaults)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
